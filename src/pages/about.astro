---
import Layout from "../layouts/IndexLayout.astro";
import thm from "../data/tryhackme.json";
import htb from "../data/htb.json";

const { username: thmUser, profileUrl: thmUrl, badgeIframe } = thm;
const { username: htbUser, profileUrl: htbUrl } = htb;
const year = new Date().getFullYear();
---

<Layout hideFooter={true}>
  <main class="page">

    <nav class="topnav">
      <a class="navlink" href="/">home</a>
      <a class="navlink active" href="/about">about</a>
      <a class="navlink" href="/writeups">write-ups</a>
    </nav>

    <section class="hero">
      <div class="c tl"></div><div class="c tr"></div>
      <div class="c bl"></div><div class="c br"></div>
      <div class="hero-aura"></div>
      <div class="hero-scan"></div>
      <div class="hero-inner">
        <div class="pretag">// profile</div>
        <div class="avi">
          <svg viewBox="0 0 24 24" width="22" height="22">
            <path fill="currentColor" d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm2.5 5.5 2.75 2.25L6.5 14.5l1 1 4-3.25-4-3.25-1 1ZM11 15h5v-1.5h-5V15Z"/>
          </svg>
        </div>
        <p class="sub">
          CS student graduating 2026. Majoring in Robotics.<br/>
          My crime is that of curiosity.
        </p>
        <div class="hero-btns">
          <a class="hbtn p" href={thmUrl} target="_blank" rel="noopener">
            <span class="br2">[</span> TryHackMe ({thmUser}) <span class="br2">]</span>
          </a>
          <a class="hbtn" href={htbUrl} target="_blank" rel="noopener">
            <span class="br2">[</span> Hack The Box ({htbUser}) <span class="br2">]</span>
          </a>
        </div>
      </div>
    </section>

    <section class="sec">
      <div class="sec-label">// activity</div>
      <div class="cards">
        <a class="card thm" href={thmUrl} target="_blank" rel="noopener">
          <span class="pill thm-pill">TryHackMe</span>
          <div class="badge">
            <div set:html={badgeIframe}></div>
          </div>
        </a>
        <a class="card htb" href={htbUrl} target="_blank" rel="noopener">
          <span class="pill htb-pill">Hack The Box</span>
          <div class="htb-mock">
            <img
              src="/htb-logo.png"
              alt="Hack The Box"
              class="htb-logo"
              onerror="this.src='https://resources.hackthebox.com/hubfs/HTB-Logo-1.png'"
            />
            <div class="htb-user">// {htbUser}</div>
          </div>
        </a>
      </div>
    </section>

    <section class="sec">
      <div class="sec-label">// env</div>
      <div class="env-grid">
        <a href="https://python.org" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Python-3776AB?style=for-the-badge&logo=python&logoColor=white" /></a>
        <a href="https://cplusplus.com" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/C++-00599C?style=for-the-badge&logo=cplusplus&logoColor=white" /></a>
        <a href="https://archlinux.org" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Arch_Linux-1793D1?style=for-the-badge&logo=arch-linux&logoColor=white" /></a>
        <a href="https://microsoft.com/powershell" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/PowerShell-5391FE?style=for-the-badge&logo=powershell&logoColor=white" /></a>
        <a href="https://neovim.io" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Neovim-57A143?style=for-the-badge&logo=neovim&logoColor=white" /></a>
        <a href="https://portswigger.net/burp" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Burp_Suite-FF6633?style=for-the-badge&logo=burpsuite&logoColor=white" /></a>
        <a href="https://nmap.org" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Nmap-004E8C?style=for-the-badge" /></a>
        <a href="https://wireshark.org" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Wireshark-1679A7?style=for-the-badge&logo=wireshark&logoColor=white" /></a>
        <a href="https://ghidra-sre.org" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Ghidra-FC0000?style=for-the-badge" /></a>
        <a href="https://microsoft.com/en-us/security/business/identity-access/microsoft-entra-id" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Active_Directory-003366?style=for-the-badge&logo=microsoft&logoColor=white" /></a>
        <a href="https://bloodhound.readthedocs.io" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/BloodHound-8A2BE2?style=for-the-badge" /></a>
        <a href="https://github.com/fortra/impacket" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Impacket-111111?style=for-the-badge" /></a>
        <a href="https://tryhackme.com/p/N22" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/TryHackMe-212C42?style=for-the-badge&logo=tryhackme&logoColor=white" /></a>
        <a href="https://torproject.org" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/Tor-7D4698?style=for-the-badge&logo=tor-project&logoColor=white" /></a>
        <a href="https://app.hackthebox.com/users/957027" target="_blank" rel="noopener"><img src="https://img.shields.io/badge/HackTheBox-9FEF00?style=for-the-badge&logo=hackthebox&logoColor=black" /></a>
      </div>
    </section>

    <section class="sec">
      <div class="sec-label">// skills</div>
      <div class="skills-grid">

        <article class="sk">
          <h3>Programming</h3>
          <div class="sk-items">
            <span class="sk-item">Python</span>
            <span class="sk-item">C++</span>
            <span class="sk-item">Rust</span>
            <span class="sk-item">HTML / CSS</span>
            <span class="sk-item">Swift</span>
          </div>
          <p class="sk-note">Building an iOS app alongside security work. Scripting for fun with PowerShell 7.</p>
        </article>

        <article class="sk">
          <h3>Offensive Security</h3>
          <div class="sk-items">
            <span class="sk-item">Web exploitation</span>
            <span class="sk-item">Privilege escalation</span>
            <span class="sk-item">Active Directory attacks</span>
            <span class="sk-item">OSINT</span>
            <span class="sk-item">Cryptography</span>
            <span class="sk-item">Forensics</span>
            <span class="sk-item">Pwn</span>
          </div>
          <p class="sk-note">14 HTB events · 59 flags · monthly CTF competitor.</p>
        </article>

        <article class="sk">
          <h3>Defensive</h3>
          <div class="sk-items">
            <span class="sk-item">HTB Sherlocks</span>
            <span class="sk-item">LetsDefend</span>
            <span class="sk-item">Log analysis & triage</span>
            <span class="sk-item">Malware analysis</span>
          </div>
          <p class="sk-note">Blue team awareness makes you a better attacker.</p>
        </article>

        <article class="sk mid">
          <h3>For Fun</h3>
          <div class="sk-items">
            <span class="sk-item">CTF / Hacking competitions</span>
            <span class="sk-item">Coding competitions</span>
            <span class="sk-item">PowerShell scripting</span>
            <span class="sk-item">Replicating CVEs</span>
            <span class="sk-item">GeoGuessr — top 1%</span>
            <span class="sk-item">Chess</span>
            <span class="sk-item">Philosophy</span>
            <span class="sk-item">Research & deep dives</span>
          </div>
          <p class="sk-note">If I'm not studying, I'm probably doing one of these.</p>
        </article>

      </div>

      <div class="focus">
        <div class="focus-row">
          <span class="ftag cur">focused</span>
          binary analysis 
        </div>
        <div class="focus-row">
          <span class="ftag dev">developing</span>
          iOS application · CTFtime integration · OSINT toolkit · project showcase
        </div>
        <div class="focus-row">
          <span class="ftag proj">projects</span>
            iOS app · OSINT Chrome extension · ESP32 wireless analyzer
        </div>
      </div>
    </section>

  </main>

  <footer class="foot">
    <span>© {year} N22</span>
    <div class="foot-links">
      <a href="https://github.com/0xN22" target="_blank" rel="noopener">GitHub</a>
      <a href="/writeups">Write-ups</a>
    </div>
  </footer>

</Layout>

<style>
  .page {
    width: min(100%, 980px);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .topnav {
    display: flex;
    gap: .6rem;
    justify-content: center;
    padding: .6rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(110,75,255,0.15);
    border-radius: 6px;
    background: rgba(110,75,255,0.03);
  }
  .navlink {
    font-family: 'Share Tech Mono', monospace;
    font-size: .72rem;
    letter-spacing: .1em;
    text-decoration: none;
    color: rgba(150,140,200,0.45);
    padding: .28rem .7rem;
    border-radius: 3px;
    transition: all .15s;
  }
  .navlink:hover { color: #fff; background: rgba(110,75,255,0.1); }
  .navlink.active {
    color: #fff;
    background: rgba(110,75,255,0.15);
    border: 1px solid rgba(110,75,255,0.3);
  }

  .hero {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(110,75,255,0.22);
    border-radius: 14px;
    padding: clamp(2rem,6vw,3.5rem) clamp(1.5rem,5vw,3rem);
    background: linear-gradient(160deg, rgba(14,9,32,.97), rgba(5,4,16,.99));
    text-align: center;
    margin-bottom: 2.5rem;
    box-shadow: 0 0 0 1px rgba(110,75,255,0.06), 0 24px 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.03);
  }
  .c { position: absolute; width: 16px; height: 16px; }
  .tl { top:0; left:0;    border-top:2px solid rgba(124,77,255,.5); border-left:2px solid rgba(124,77,255,.5); }
  .tr { top:0; right:0;   border-top:2px solid rgba(124,77,255,.5); border-right:2px solid rgba(124,77,255,.5); }
  .bl { bottom:0; left:0;  border-bottom:2px solid rgba(124,77,255,.5); border-left:2px solid rgba(124,77,255,.5); }
  .br { bottom:0; right:0; border-bottom:2px solid rgba(124,77,255,.5); border-right:2px solid rgba(124,77,255,.5); }
  .hero-aura {
    position: absolute; inset: -50% -30% auto; height: 80%;
    background: radial-gradient(55% 55% at 50% 45%, rgba(110,75,255,.3) 0%, rgba(94,123,255,.08) 45%, transparent 70%);
    filter: blur(55px); pointer-events: none;
    animation: pulse 7s ease-in-out infinite alternate;
  }
  @keyframes pulse { from{opacity:.6;transform:scaleX(1)} to{opacity:1;transform:scaleX(1.08)} }
  .hero-scan {
    position: absolute; inset: 0; border-radius: inherit; pointer-events: none;
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.06) 2px, rgba(0,0,0,.06) 4px);
  }
  .hero-inner { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; }
  .pretag {
    font-family: 'Share Tech Mono', monospace;
    font-size: .68rem; letter-spacing: .2em;
    color: rgba(124,77,255,.55); margin-bottom: 1rem;
  }
  .avi {
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; border-radius: 50%; color: #fff;
    background: linear-gradient(135deg,#7c4dff,#5e7bff);
    box-shadow: 0 8px 28px rgba(94,123,255,.3);
    margin-bottom: 1rem;
  }
  .sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(.88rem,2vw,.98rem);
    color: rgba(200,195,230,.6);
    line-height: 1.75; max-width: 52ch;
    margin: 0 auto 1.8rem;
  }
  .sub strong { color: rgba(160,140,255,.9); font-weight: 400; }
  .hero-btns { display: flex; gap: .75rem; flex-wrap: wrap; justify-content: center; }
  .hbtn {
    font-family: 'Share Tech Mono', monospace;
    font-size: .78rem; letter-spacing: .05em;
    display: inline-flex; align-items: center; gap: .3rem;
    padding: .58rem 1.1rem;
    border: 1px solid rgba(110,75,255,.28); border-radius: 4px;
    text-decoration: none; color: rgba(210,205,240,.8);
    background: rgba(110,75,255,.05); transition: all .15s;
  }
  .br2 { color: rgba(124,77,255,.4); }
  .hbtn:hover { background: rgba(110,75,255,.12); border-color: rgba(110,75,255,.5); color: #fff; transform: translateY(-2px); }
  .hbtn.p { border-color: transparent; background: linear-gradient(135deg,#7c4dff,#5e7bff); color: #fff; box-shadow: 0 4px 20px rgba(94,123,255,.25); }
  .hbtn.p:hover { filter: brightness(1.12); border-color: transparent; }

  .sec { margin-bottom: 2.5rem; }
  .sec-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: .78rem;
    letter-spacing: .18em;
    color: rgba(180,165,255,0.9);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: .8rem;
  }
  .sec-label::after {
    content: ''; flex: 1; height: 1px;
    background: linear-gradient(90deg, rgba(110,75,255,.35), transparent);
  }

  .cards { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(260px,1fr)); }
  .card {
    text-decoration: none; color: inherit;
    border: 1px solid rgba(110,75,255,.15); border-radius: 10px;
    padding: 1.2rem; background: rgba(10,6,26,.7);
    display: flex; flex-direction: column; align-items: center;
    min-height: 180px; position: relative; overflow: hidden;
    transition: all .18s;
  }
  .card.thm:hover { border-color: rgba(124,77,255,.45); box-shadow: 0 0 28px rgba(124,77,255,.1); transform: translateY(-3px); }
  .card.htb:hover { border-color: rgba(0,229,255,.35); box-shadow: 0 0 28px rgba(0,229,255,.08); transform: translateY(-3px); }
  .pill {
    font-family: 'Share Tech Mono', monospace;
    font-size: .62rem; letter-spacing: .12em; text-transform: uppercase;
    padding: .18rem .55rem; border-radius: 2px; margin-bottom: .9rem;
    border: 1px solid; font-weight: 700;
  }
  .thm-pill { background: rgba(124,77,255,.12); color: rgba(160,140,255,.85); border-color: rgba(124,77,255,.28); }
  .htb-pill { background: rgba(0,229,255,.07); color: rgba(0,229,255,.75); border-color: rgba(0,229,255,.2); }
  .badge {
    position: relative; width: 100%; max-width: 480px;
    aspect-ratio: 520/180; border-radius: 8px; overflow: hidden;
  }
  .badge :global(iframe) {
    position: absolute; top: 0; left: 50%;
    transform: translateX(-30%);
    width: 120%; height: 100%; border: 0;
  }
  .htb-mock { display: flex; flex-direction: column; align-items: center; gap: .5rem; flex: 1; justify-content: center; }
  .htb-logo { max-width: 130px; opacity: .85; transition: opacity .2s, transform .15s; }
  .htb-logo:hover { opacity: 1; transform: translateY(-1px); }
  .htb-user { font-family: 'Share Tech Mono', monospace; font-size: .72rem; color: rgba(150,140,200,.4); letter-spacing: .1em; }

  .env-grid { display: flex; flex-wrap: wrap; gap: .5rem; }
  .env-grid a { display: inline-flex; }
  .env-grid img { border-radius: 2px; filter: brightness(.88) contrast(1.05); transition: filter .15s; }
  .env-grid img:hover { filter: brightness(1.05) contrast(1.1); }

  .skills-grid { display: grid; gap: .9rem; grid-template-columns: repeat(auto-fill, minmax(240px,1fr)); }
  @media (min-width: 860px) {
    .skills-grid { grid-template-columns: repeat(3,1fr); }
    .sk.mid { grid-column: 2; }
  }
  .sk {
    border: 1px solid rgba(110,75,255,.13); border-radius: 10px;
    padding: 1.1rem 1.15rem 1.2rem; background: rgba(10,6,26,.7);
    transition: all .18s; position: relative; overflow: hidden;
  }
  .sk::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(124,77,255,.3), transparent);
    opacity: 0; transition: opacity .2s;
  }
  .sk:hover::before { opacity: 1; }
  .sk:hover { transform: translateY(-3px); border-color: rgba(124,77,255,.28); box-shadow: 0 12px 32px rgba(0,0,0,.4); }
  .sk h3 {
    font-family: 'Share Tech Mono', monospace;
    font-size: .78rem; letter-spacing: .1em; text-transform: uppercase;
    color: #fff; margin-bottom: .8rem; font-weight: 400;
  }
  .sk-items { display: flex; flex-direction: column; gap: .25rem; margin-bottom: .65rem; }
  .sk-item { font-family: 'Share Tech Mono', monospace; font-size: .82rem; color: #c8d8e4; }
  .sk-item::before { content: '> '; color: rgba(124,77,255,.5); }
  .sk-note { font-family: 'DM Sans', sans-serif; font-size: .85rem; color: rgba(200,210,220,0.6); line-height: 1.6; }
  .sk-lede { font-family: 'DM Sans', sans-serif; font-size: .85rem; color: rgba(160,140,255,.7); line-height: 1.6; margin-bottom: .35rem; }

  .focus { display: flex; flex-direction: column; gap: .45rem; margin-top: 1.4rem; }
  .focus-row {
    font-family: 'Share Tech Mono', monospace;
    font-size: .72rem; color: rgba(150,140,200,.4);
    display: flex; align-items: center; gap: .55rem;
  }
  .ftag { font-size: .62rem; letter-spacing: .1em; text-transform: uppercase; padding: .15rem .48rem; border-radius: 2px; border: 1px solid; }
  .ftag.cur { background: rgba(124,77,255,.1); color: rgba(160,140,255,.75); border-color: rgba(124,77,255,.22); }
  .ftag.dev { background: rgba(0,229,255,.05); color: rgba(0,229,255,.55); border-color: rgba(0,229,255,.16); }
  .ftag.proj { background: rgba(74,222,128,.05); color: rgba(74,222,128,.6); border-color: rgba(74,222,128,.18); }

  .foot {
    border-top: 1px solid rgba(110,75,255,.1);
    padding: 1rem 1.5rem; margin-top: 1rem;
    display: flex; align-items: center; justify-content: space-between;
    font-family: 'Share Tech Mono', monospace;
    font-size: .68rem; letter-spacing: .08em;
    color: rgba(150,140,200,.3);
    width: min(100%,980px); margin-inline: auto;
  }
  .foot-links { display: flex; gap: 1rem; }
  .foot-links a { color: rgba(150,140,200,.3); text-decoration: none; transition: color .15s; }
  .foot-links a:hover { color: rgba(160,140,255,.7); }

  *::selection { background: rgba(124,77,255,.28); color: #fff; }
</style>