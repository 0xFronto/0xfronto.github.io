---
export interface Props { hideFooter?: boolean }
const { hideFooter = false } = Astro.props;
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>N22</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Share+Tech+Mono&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <body>
    <slot />

    {!hideFooter && (
      <footer class="site-foot">
        <div class="site-foot__container">
          <span>© {new Date().getFullYear()} N22</span>
          <nav class="site-foot__links">
            <a href="https://github.com/0xN22" target="_blank" rel="noopener">GitHub</a>
          </nav>
        </div>
      </footer>
    )}
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    min-height: 100vh;
    background: #07060f;
    color: #c8d0e0;
    font-family: 'DM Sans', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 2px,
      rgba(0,0,0,0.07) 2px, rgba(0,0,0,0.07) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  a { color: inherit; }

  .site-foot {
    border-top: 1px solid rgba(110,75,255,0.15);
    margin-top: 2rem;
  }
  .site-foot__container {
    width: min(100%, 1040px);
    margin-inline: auto;
    padding: 0.9rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(150,140,200,0.4);
  }
  .site-foot__links { display: flex; gap: 0.9rem; }
  .site-foot__links a {
    color: rgba(150,140,200,0.4);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .site-foot__links a:hover { color: rgba(160,140,255,0.9); }

  @media (max-width: 640px) {
    .site-foot__container { flex-direction: column; gap: 0.5rem; }
  }
</style>